# Gerçek değerleri asla bu dosyaya yazmayın / commit etmeyin.
# Bu, sadece hangi değişkenlerin gerektiğini gösteren bir şablondur.

# Backend hiçbir zaman Anthropic Messages API'sini kendi çağırmaz -- Claude (kullanıcının
# kendi Claude.ai/Desktop/Code hesabı) bu servere remote MCP client olarak bağlanır, LLM
# çağrısını kullanıcının kendi tarafı yapar. Bu yüzden burada bir ANTHROPIC_API_KEY yoktur.
#
# Aynı şekilde tek bir sabit GOOGLE_ADS_REFRESH_TOKEN/LOGIN_CUSTOMER_ID de yoktur -- her
# kullanıcı kendi Google OAuth akışıyla bağlanır, refresh token'ı vault'a, login_customer_id'si
# DB'ye (ads_account) yazılır (docs/AUTH.md).

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Connector'ın kendi OAuth 2.1 AS'i (backend/src/auth/, ADR-0002) için:
PUBLIC_BASE_URL=http://localhost:8000
MCP_RESOURCE_PATH=/mcp
# Yalnız backend/src/auth/vault.py::LocalEncryptedVault (yerel/dev) için --
# üretim secrets manager'ının yerine GEÇMEZ. Fernet.generate_key() ile üretilir.
LOCAL_VAULT_KEY=

# Production PostgreSQL DSN. Yerel SQLite prototip varsayılan çalıştırma yolu olarak kalır;
# production SQLAlchemy helper'ları bunu ister ve yalnız postgresql dialect'ini kabul eder.
DATABASE_URL=

# Ortam adı: "local" dışındaki her değer Secure cookie + HSTS'i açar (docs/SECURITY.md).
APP_ENVIRONMENT=local
# Virgülle ayrılmış Host allowlist'i. Boşsa PUBLIC_BASE_URL'in hostname'i tek başına
# kullanılır -- deployment birden fazla hostname'e yanıt veriyorsa burada listeleyin.
ALLOWED_HOSTS=
# Virgülle ayrılmış, tarayıcıdan çapraz-origin erişimine izin verilecek origin listesi.
# Boş (varsayılan) = çapraz-origin erişim yok. Asla "*" kullanmayın (docs/SECURITY.md
# "CORS açık allowlist'tir").
CORS_ALLOWED_ORIGINS=

# Üretimde bu değerler .env yerine bir secrets manager'dan okunmalı.
# Runtime-tuned fair-use buckets; provider constants degildir.
RATE_LIMIT_GLOBAL_CAPACITY=60
RATE_LIMIT_GLOBAL_REFILL_PER_SECOND=1
RATE_LIMIT_PRINCIPAL_CUSTOMER_CAPACITY=10
RATE_LIMIT_PRINCIPAL_CUSTOMER_REFILL_PER_SECOND=0.2
